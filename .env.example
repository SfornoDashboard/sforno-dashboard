# Copia questo file in .env e compila i valori.
# Su Vercel aggiungi queste stesse variabili in Settings > Environment Variables.

# Il tuo username GitHub
VITE_GITHUB_OWNER=tuo-username-github

# Il nome del repository dove hai caricato questo progetto
VITE_GITHUB_REPO=sforno-dashboard

# Personal Access Token GitHub con permesso "Contents: Read & Write"
# Crea su: https://github.com/settings/tokens?type=beta
VITE_GITHUB_TOKEN=github_pat_xxxxx
